{
  "name": "localspace",
  "description": "A Promise-first storage toolkit for IndexedDB, localStorage, memory, and React Native AsyncStorage",
  "version": "2.0.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "author": "unadlib",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unadlib/localspace.git"
  },
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react-native": [
        "dist/react-native.d.ts"
      ]
    }
  },
  "unpkg": "./dist/index.umd.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      }
    },
    "./react-native": {
      "require": {
        "types": "./dist/react-native.d.cts",
        "default": "./dist/react-native.cjs"
      },
      "default": {
        "types": "./dist/react-native.d.ts",
        "default": "./dist/react-native.esm.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "test": "vitest run && pnpm run build && node test/package-exports.cjs && pnpm run test:types:package && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:rn:integration:setup": "pnpm --filter localspace-rn-integration install --prod=false",
    "test:rn:integration": "pnpm run test:rn:integration:setup && pnpm run build && pnpm -C integration/react-native-jest test",
    "test:e2e": "pnpm run build && playwright test",
    "test:exports": "pnpm run build && node test/package-exports.cjs && pnpm run test:types:package",
    "test:types:package": "tsc -p test/package-types/tsconfig.json",
    "test:e2e:coverage": "rimraf .nyc_output && pnpm run build && PLAYWRIGHT_COVERAGE=1 playwright test && nyc report --reporter=text-summary --reporter=html",
    "coverage:full": "rimraf coverage .nyc_output && vitest run --coverage && node -e \"const fs=require('fs');const path=require('path');const src=path.join('coverage','coverage-final.json');if(!fs.existsSync(src)){console.error('Vitest coverage JSON not found:',src);process.exit(1);}fs.mkdirSync('.nyc_output',{recursive:true});fs.copyFileSync(src,path.join('.nyc_output','vitest.json'));\" && pnpm run build && PLAYWRIGHT_COVERAGE=1 playwright test && nyc report --reporter=text-summary --reporter=html",
    "clean": "rimraf dist",
    "check:type": "tsc --skipLibCheck --noEmit && tsc --skipLibCheck -p tsconfig.examples.json",
    "build": "pnpm run clean && tsc --skipLibCheck && pnpm run build:types:cjs && pnpm run build:prod",
    "build:types:cjs": "node scripts/build-cjs-types.mjs",
    "build:prod": "NODE_ENV=production rolldown --config rolldown.config.ts",
    "build:doc": "typedoc --plugin typedoc-plugin-markdown --out docs src/index.ts",
    "commit": "pnpm exec git-cz",
    "format": "prettier --write src"
  },
  "keywords": [
    "indexeddb",
    "localstorage",
    "storage"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^3.2.4",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.3.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "fake-indexeddb": "^6.2.4",
    "jsdom": "^27.0.0",
    "localforage": "^1.10.0",
    "nyc": "^17.1.0",
    "prettier": "^3.2.5",
    "rimraf": "^6.0.1",
    "rolldown": "^1.0.3",
    "serve": "^14.2.5",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.2.10",
    "typescript": "^5.9.2",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "^3.2.4"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  }
}
